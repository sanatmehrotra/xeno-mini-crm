# =============================================================================
# channel-service — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env — it contains the HMAC secret.
# =============================================================================

PORT=8001

# URL where crm-backend's webhook lives
# LOCAL (docker compose): http://crm-backend:8000/api/v1/webhooks/channel-receipt
# PRODUCTION: https://your-crm-domain.com/api/v1/webhooks/channel-receipt
CRM_CALLBACK_URL=http://crm-backend:8000/api/v1/webhooks/channel-receipt

# Must match CHANNEL_HMAC_SECRET in crm-backend/.env exactly
HMAC_SECRET=change-me-32-char-secret-here!!!
