# =============================================================================
# crm-backend — Environment Variables Reference
# =============================================================================
# LOCAL DEV: copy to .env and fill in values
#   cp .env.example .env
#
# RAILWAY PRODUCTION: set these in Railway → project → Variables tab.
# Never commit .env — it contains secrets.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Railway auto-provides this when you add a Postgres plugin.
# Format for async driver: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/xeno_crm

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway auto-provides this when you add a Redis plugin.
REDIS_URL=redis://localhost:6379/0

# ── Channel service ───────────────────────────────────────────────────────────
# In Railway: set to the Railway internal URL of the channel-service (if deployed),
# or your channel-service public URL.
CHANNEL_SERVICE_URL=http://localhost:8001
CHANNEL_HMAC_SECRET=change-me-32-char-secret-here!!!   # min 32 chars, random string

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-here                    # use: openssl rand -hex 32
JWT_EXPIRY_HOURS=24

# ── Admin credentials ─────────────────────────────────────────────────────────
# Single-admin system — no user registration.
ADMIN_EMAIL=admin@yourdomain.com
# Generate hash: python scripts/hash_password.py yourpassword
# For Railway, do NOT escape $ — Railway handles it natively.
# For docker-compose, escape $ as $$
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_YOUR_HASH

# ── AI (OpenRouter) ───────────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
AI_MODEL_FAST=google/gemini-flash-1.5
AI_MODEL_SMART=anthropic/claude-3.5-sonnet

# ── Attribution window ────────────────────────────────────────────────────────
ATTRIBUTION_WINDOW_HOURS=72

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated. Add your Render frontend URL here.
# Example: FRONTEND_ORIGINS=https://brewbharat.onrender.com,http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000
