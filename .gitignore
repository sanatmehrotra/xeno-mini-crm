# =============================================================================
# .gitignore — BrewBharat CRM (monorepo)
# Root covers both backend/ and frontend/
# =============================================================================

# =============================================================================
# SECRETS — NEVER commit these
# =============================================================================
.env
.env.local
.env.production
.env.*.local
*.env
backend/crm-backend/.env
backend/channel-service/.env
frontend/.env.local
frontend/.env.production

# =============================================================================
# backend/docs — only ARCHITECTURE.md is tracked; ignore all others explicitly
# =============================================================================
backend/docs/AI_WORKFLOW.md
backend/docs/CHANGELOG.md
backend/docs/CONTRIBUTING.md
backend/docs/DECISIONS.md

# =============================================================================
# Python (backend/)
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.so
*.dylib
htmlcov/
.coverage

# =============================================================================
# Node / Next.js (frontend/)
# =============================================================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/.vercel
frontend/next-env.d.ts
frontend/*.tsbuildinfo
frontend/.env*
frontend/.env.local
frontend/.env.production
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.pem

# =============================================================================
# Docker
# =============================================================================
# .dockerignore files are intentionally committed — they control build context.
# Do NOT ignore them here.

# =============================================================================
# Seed data (large JSON, not needed in repo)
# =============================================================================
backend/crm-backend/seed_data/customers.json
backend/crm-backend/seed_data/orders.json

# =============================================================================
# IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
